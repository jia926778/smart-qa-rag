# ============================================================
# Smart QA RAG - Environment Variables
# ============================================================

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# --- Embedding ---
# Provider: "openai" or "local"
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-ada-002
LOCAL_EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_db

# --- Retrieval ---
RETRIEVAL_TOP_K=4
RETRIEVAL_SCORE_THRESHOLD=0.35
RETRIEVAL_INITIAL_K=20

# --- Text splitting (Parent-Child Chunking) ---
CHUNK_SIZE=500
CHUNK_OVERLAP=80
PARENT_CHUNK_SIZE=1500
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=300
CHILD_CHUNK_OVERLAP=50

# --- Reranker ---
# Enable/disable reranking stage
RERANKER_ENABLED=true
# Provider: "cross-encoder", "llm", or "cosine"
RERANKER_PROVIDER=cross-encoder
# Cross-encoder model (only used when RERANKER_PROVIDER=cross-encoder)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Number of documents to return after reranking
RERANKER_TOP_N=4

# --- LangGraph Agent Pipeline ---
# Max quality-check retries (evaluator loops back to query_analyzer)
AGENT_MAX_RETRIES=2

# --- OCR (pytesseract) ---
OCR_ENABLED=true
# Tesseract language codes (e.g., "chi_sim+eng", "eng", "jpn+eng")
OCR_LANGUAGE=chi_sim+eng

# --- Audio/Video Transcription (Whisper) ---
WHISPER_ENABLED=true
# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# --- Upload ---
# Increased to 50MB for audio/video files
MAX_UPLOAD_SIZE_MB=50

# --- Logging ---
LOG_LEVEL=INFO
